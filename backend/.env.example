# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/subsaver

# --- Environnement ---
# "production" active les garde-fous stricts de app/core/config.py (refuse de
# démarrer si SECRET_KEY est resté à sa valeur par défaut ou fait < 32
# caractères). Laisser "development" en local/CI -- ne jamais mettre
# "production" sans avoir configuré un vrai SECRET_KEY, sous peine de voir
# l'application refuser de démarrer (c'est le but recherché).
ENVIRONMENT=development

# --- Sécurité JWT ---
# Génère une vraie valeur en production, ex: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Chiffrement au repos des tokens Powens ---
# Génère une clé, ex: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Vide en dev : le chiffrement est alors un no-op (comportement préexistant préservé).
TOKEN_ENCRYPTION_KEY=

# --- CORS (liste JSON des origines autorisées) ---
# En production (Render), doit lister TOUTES les origines par lesquelles les
# utilisateurs accèdent réellement au frontend -- y compris les domaines
# personnalisés (ex: subsaver.fr), sans quoi le navigateur bloque les appels
# API avec "Disallowed CORS origin" alors que l'URL onrender.com fonctionne.
CORS_ORIGINS=["http://localhost:5173","https://subserver-frontend.onrender.com","https://subsaver.fr","https://www.subsaver.fr"]

# --- Google Sign-In (flux "ID token") ---
# Client ID "Application Web" créé dans Google Cloud Console (Écran de
# consentement OAuth + Identifiants). Pas de client secret ni de
# redirect_uri nécessaires : le frontend récupère un credential JWT via
# Google Identity Services, ce backend le revérifie lui-même (cf.
# app/core/security.py::verify_google_id_token).
GOOGLE_CLIENT_ID=

# --- Powens (Open Banking - Bank API, sandbox) ---
# Ne jamais committer les vraies valeurs : à définir dans les variables d'env Render.
POWENS_DOMAIN=subsaver-sandbox.biapi.pro
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=
POWENS_REDIRECT_URI=https://subsaver-frontend.onrender.com/subscriptions

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=contact.subsaver@proton.me
VERIFICATION_CODE_TTL_MINUTES=10
CONTACT_EMAIL=contact.subsaver@proton.me
